<script>
/* ============================================
   CONFIG — Web3Forms
   ============================================
   1. Vai su https://web3forms.com
   2. Crea un access key inserendo hello@fattorettosrl.it
   3. Sostituisci la stringa qui sotto
============================================ */
const WEB3FORMS_KEY = "YOUR-WEB3FORMS-ACCESS-KEY-HERE";
// L'access key deve essere generata usando l'email hello@fattorettosrl.it.
// Gli altri 3 destinatari (massimo, clarissa, maria) sono raggiunti via
// forward automatico configurato in Gmail hello@fattorettosrl.it — vedi README.

/* ========== CHIP GROUPS ========== */
document.querySelectorAll('.chip').forEach(chip=>{
  const input = chip.querySelector('input');
  chip.addEventListener('click',e=>{
    if(e.target.tagName==='INPUT')return;
    input.checked = !input.checked;
    chip.classList.toggle('checked', input.checked);
  });
  input.addEventListener('change',()=>chip.classList.toggle('checked', input.checked));
});

/* ========== FILE UPLOAD ========== */
const uploadZone = document.getElementById('uploadZone');
const fileInput = document.getElementById('fileInput');
const uploadList = document.getElementById('uploadList');
let selectedFiles = [];
const MAX_FILES = 1;  // Web3Forms free plan: solo 1 allegato via standard uploader
const MAX_SIZE = 5 * 1024 * 1024;

['dragover','dragenter'].forEach(ev=>uploadZone.addEventListener(ev,e=>{
  e.preventDefault();uploadZone.classList.add('dragover');
}));
['dragleave','drop'].forEach(ev=>uploadZone.addEventListener(ev,e=>{
  e.preventDefault();uploadZone.classList.remove('dragover');
}));
uploadZone.addEventListener('drop',e=>{
  e.preventDefault();
  handleFiles(e.dataTransfer.files);
});
fileInput.addEventListener('change',e=>handleFiles(e.target.files));

const uploadSummary = document.getElementById('uploadSummary');
const uploadTotalSize = document.getElementById('uploadTotalSize');
document.getElementById('clearAll').addEventListener('click',()=>{
  selectedFiles = [];
  renderFiles();
});

function handleFiles(files){
  for(const f of files){
    if(selectedFiles.length>=MAX_FILES){
      // Con un solo file, sostituiamo invece di bloccare — UX migliore
      selectedFiles = [];
    }
    if(f.size>MAX_SIZE){alert(f.name+' supera i 5 MB. Per file più grandi, usa il campo "Link risorse" con Drive o WeTransfer.');continue;}
    if(!f.type.startsWith('image/')){alert(f.name+' non è un\'immagine');continue;}
    selectedFiles.push(f);
    if(selectedFiles.length>=MAX_FILES) break;
  }
  renderFiles();
}
function fmtSize(bytes){
  return bytes>1024*1024 ? (bytes/1024/1024).toFixed(1)+' MB' : (bytes/1024).toFixed(0)+' KB';
}
function renderFiles(){
  uploadList.innerHTML='';
  if(selectedFiles.length===0){
    uploadSummary.classList.remove('active');
    return;
  }
  uploadSummary.classList.add('active');
  const total = selectedFiles.reduce((s,f)=>s+f.size,0);
  uploadTotalSize.textContent = fmtSize(total);

  selectedFiles.forEach((f,i)=>{
    const div = document.createElement('div');
    div.className='upload-file';
    div.innerHTML=`
      <div class="upload-file-thumb no-preview" data-i="${i}">IMG</div>
      <div class="upload-file-meta">
        <span class="fn" title="${f.name}">${f.name}</span>
        <span class="fs">${fmtSize(f.size)}</span>
      </div>
      <button type="button" class="rm" data-i="${i}" aria-label="Rimuovi">×</button>`;
    uploadList.appendChild(div);

    // Load thumbnail preview
    const thumb = div.querySelector('.upload-file-thumb');
    const reader = new FileReader();
    reader.onload = e => {
      thumb.style.backgroundImage = `url(${e.target.result})`;
      thumb.classList.remove('no-preview');
      thumb.textContent = '';
    };
    reader.readAsDataURL(f);
  });

  uploadList.querySelectorAll('.rm').forEach(btn=>{
    btn.addEventListener('click',(e)=>{
      e.preventDefault();
      e.stopPropagation();
      selectedFiles.splice(+btn.dataset.i,1);
      renderFiles();
    });
  });
}

/* ========== FORM SUBMIT ========== */
const form = document.getElementById('briefForm');
const submitBtn = document.getElementById('submitBtn');
const errorBanner = document.getElementById('errorBanner');
const successScreen = document.getElementById('successScreen');

form.addEventListener('submit', async e=>{
  e.preventDefault();
  errorBanner.classList.remove('active');

  if(!form.checkValidity()){
    form.reportValidity();
    return;
  }

  // Validate at least one settore selected
  const settoreChecked = form.querySelectorAll('input[name="settore"]:checked').length;
  if(settoreChecked===0){
    showError('Seleziona almeno un settore di riferimento (§ 01).');
    return;
  }

  // Build payload
  const formData = new FormData(form);
  const payload = new FormData();

  payload.append('access_key', WEB3FORMS_KEY);
  payload.append('subject', 'Nuovo Brief Co-Branding — ' + (formData.get('brand_name')||'Brand'));
  payload.append('from_name', 'Brief Fattoretto — ' + (formData.get('brand_name')||''));
  payload.append('replyto', formData.get('email_ref')||'');

  // Collect grouped fields
  const settoreVals = Array.from(form.querySelectorAll('input[name="settore"]:checked')).map(i=>i.value).join(', ');

  // Human-readable message
  const msg = `
════════════════════════════════════════
  BRIEF CO-BRANDING · FATTORETTO AGENCY
════════════════════════════════════════

▸ Ricevuto: ${new Date().toLocaleString('it-IT')}

────────────────────────────────────────
§ 01 — IDENTITÀ
────────────────────────────────────────
Brand:            ${formData.get('brand_name')||'—'}
Sito web:         ${formData.get('website')||'—'}
Referente:        ${formData.get('referente')||'—'}
Email contatto:   ${formData.get('email_ref')||'—'}
Settore:          ${settoreVals||'—'}
Mercati:          ${formData.get('mercati')||'—'}

────────────────────────────────────────
§ 02 — POSIZIONAMENTO & NARRATIVA
────────────────────────────────────────
▸ Racconto del brand:
${formData.get('descrizione')||'—'}

▸ Valori del brand:
${formData.get('valori')||'—'}

▸ Tone of voice:
${formData.get('tone_of_voice')||'—'}

▸ Target di riferimento:
${formData.get('target')||'—'}

────────────────────────────────────────
§ 03 — OFFERTA & PUNTI FORTI
────────────────────────────────────────
▸ Punti essenziali dell'offerta:
${formData.get('offerta')||'—'}

▸ USP — cosa vi rende unici:
${formData.get('usp')||'—'}

▸ Dati & numeri raccontabili:
${formData.get('dati_numeri')||'—'}

▸ Storie & retroscena:
${formData.get('storie')||'—'}

▸ Competitor:
${formData.get('competitor')||'—'}

────────────────────────────────────────
§ 04 — ASSET & MATERIALI
────────────────────────────────────────
File allegati:    ${selectedFiles.length} file (allegato: ${selectedFiles.length>0 ? selectedFiles[0].name : 'nessuno'}${selectedFiles.length>1 ? ' — gli altri '+(selectedFiles.length-1)+' file sono stati compressi in preview ma non allegati per limite piano gratuito. Chiedere al cliente il link Drive/WeTransfer.' : ''})
Link risorse:     ${formData.get('risorse_link')||'—'}

▸ Note finali:
${formData.get('note')||'—'}

════════════════════════════════════════
`;
  payload.append('message', msg);

  // Add individual fields (Web3Forms will list them too)
  ['brand_name','website','referente','email_ref','mercati','descrizione','valori','tone_of_voice','target','offerta','usp','dati_numeri','storie','competitor','risorse_link','note'].forEach(k=>{
    payload.append(k, formData.get(k)||'');
  });
  payload.append('settore', settoreVals);

  // Attach first file only (Web3Forms free plan: 1 file, max 5MB via standard uploader).
  // Per allegati multipli è richiesto piano PRO. Vedi note nel README.
  // In alternativa, invitare il cliente a caricare le immagini in Drive/WeTransfer
  // e incollare il link nel campo "Link risorse".
  if(selectedFiles.length > 0){
    payload.append('attachment', selectedFiles[0], selectedFiles[0].name);
  }

  // Honeypot
  payload.append('botcheck', form.querySelector('[name=botcheck]').checked ? 'true' : '');

  // UI: loading
  submitBtn.disabled = true;
  submitBtn.innerHTML = '<span class="spinner"></span> Invio in corso…';

  try{
    const res = await fetch('https://api.web3forms.com/submit', {
      method:'POST',
      body: payload
    });
    const data = await res.json();
    if(data.success){
      successScreen.classList.add('active');
      window.scrollTo({top:0, behavior:'smooth'});
    }else{
      throw new Error(data.message||'Errore invio.');
    }
  }catch(err){
    showError('Si è verificato un problema durante l\'invio: '+err.message+' — Riprova o scrivici direttamente a hello@fattorettosrl.it');
    submitBtn.disabled = false;
    submitBtn.innerHTML = 'Invia il brief <span class="arrow">→</span>';
  }
});

function showError(txt){
  errorBanner.textContent = txt;
  errorBanner.classList.add('active');
  errorBanner.scrollIntoView({behavior:'smooth', block:'center'});
}
</script>

